# Fichiers temporaires Office
~$*

# Dépendances npm
node_modules/

# Build Vite (W12)
dist/

# Cache Vite
.vite/

# Playwright
playwright-report/
test-results/

# Couverture Vitest (W72)
coverage/

# Journal direct de commit.sh
commit.log

# Config GAS — contient scriptId, sheetId, deployId (données sensibles)
.claude/gas-config.json

# Sauvegardes VBA horodatées (transient, non versionné)
vba-backup-*/

# Sauvegardes locales path-spécifiques + fichiers temp VBA (non versionnés)
vba/backup/
vba/backup_*/
excel/backup/
excel/backup_*/
temp_*.bas

# Fichiers vides parasites (redirection shell mal interprétée par hooks / messages de commit) — ne jamais versionner
/$null
/code
/corrige
/reconstruire
/ui-coder
/sheetname

# Les maquettes y sont stockées
.superpowers/

# Graphify — ne suivre que le graphe publié ; ignorer tous les artefacts de build/cache
# (temporaires .graphify_*, cache/ de --update, converted/, _build.py, manifest/cost…)
graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md
!graphify-out/graph.html
# Sauvegardes VBA de session (transient, non versionné)
backups/
excel/_vba_backup/

# Claude-flow (runtime local, non versionné)
.claude-flow/
# Backups CLAUDE.md horodatés (transient)
CLAUDE.md.bak-*
