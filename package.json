{
  "name": "suivi-conso-carburant",
  "version": "5.21.2.0",
  "description": "Formulaire mobile de saisie des pleins carburant (E85/SP98/Gazole…) — GitHub Pages + Google Sheets",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --base /suivi-conso-carburant/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint js/ --max-warnings=0",
    "gas:deploy": "node gas-deploy.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "js/**/*.js": [
      "eslint --max-warnings=0",
      "vitest related --run"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.44.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0"
  }
}
